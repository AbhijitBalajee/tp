@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:FilterCommand</u>" as FC
participant "<u>:FindCommand</u>" as FNC
participant "<u>:FindByKeywordCommand</u>" as FKC
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Ui</u>" as UI

User -> ST : "filter from/2026-03-01 to/2026-03-31 [c/Food]"
activate ST

ST -> P : parse(input)
activate P
P -> P : parseFilterCommand(args)
note right of P
  Extracts from/, to/, c/ tokens
  via DateParser.parse()
  Rejects unknown tokens and '|' in c/
  Validates from <= to
end note
create "<u>:FilterCommand</u>" as FC
P -> FC : new FilterCommand(from, to, category)
activate FC
FC --> P
deactivate FC
P --> ST : :FilterCommand(from, to, category)
deactivate P

ST -> FC : execute(expenseList, ui)
activate FC

loop for each expense in expenseList
    FC -> EL : getExpense(i)
    activate EL
    EL --> FC : expense
    deactivate EL
    FC -> FC : check date in [from, to]
    opt category filter set
        FC -> FC : check category matches (case-insensitive)
    end
end

FC -> UI : showFilteredExpenses(filtered, from, to, category)
activate UI
UI --> FC
deactivate UI
FC --> ST
deactivate FC
ST --> User : filtered expense table
deactivate ST

User -> ST : "find 2"
activate ST

ST -> P : parse(input)
activate P
P -> P : parseFindCommand(args)
note right of P
  Single token only — rejects trailing garbage
  Integer parsed -> FindCommand
end note
create "<u>:FindCommand</u>" as FNC
P -> FNC : new FindCommand(2)
activate FNC
FNC --> P
deactivate FNC
P --> ST : :FindCommand(2)
deactivate P

ST -> FNC : execute(expenseList, ui)
activate FNC

FNC -> EL : size()
activate EL
EL --> FNC : size
deactivate EL

opt index out of range or list empty
    FNC -> FNC : throw SpendTrackException
end

FNC -> EL : getExpense(index - 1)
activate EL
EL --> FNC : expense
deactivate EL
FNC -> UI : showExpenseDetail(index, expense)
activate UI
UI --> FNC
deactivate UI
FNC --> ST
deactivate FNC
ST --> User : detailed expense view (incl. Recurring)
deactivate ST

User -> ST : "find d/coffee"
activate ST

ST -> P : parse(input)
activate P
P -> P : parseFindCommand(args)
note right of P
  Detects d/ prefix
  Validates keyword non-empty, no '|'
end note
create "<u>:FindByKeywordCommand</u>" as FKC
P -> FKC : new FindByKeywordCommand("coffee")
activate FKC
FKC --> P
deactivate FKC
P --> ST : :FindByKeywordCommand("coffee")
deactivate P

ST -> FKC : execute(expenseList, ui)
activate FKC

loop for each expense in expenseList
    FKC -> EL : getExpense(i)
    activate EL
    EL --> FKC : expense
    deactivate EL
    FKC -> FKC : check description contains keyword (case-insensitive)
end

FKC -> UI : showExpensesByKeyword(matchIndices, matches, keyword)
activate UI
UI --> FKC
deactivate UI
FKC --> ST
deactivate FKC
ST --> User : keyword search results table
deactivate ST
@enduml
