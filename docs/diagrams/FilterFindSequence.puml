@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "<<class>>\nParser" as P
participant ":FilterCommand" as FC
participant ":FindCommand" as FNC
participant ":ExpenseList" as EL
participant ":Ui" as UI

User -> ST : "filter from/2026-03-01 to/2026-03-31"
activate ST

ST -> P : parse(input)
activate P
P -> P : parseFilterCommand(args)
note right of P
  Extracts from/ and to/ dates
  via DateParser.parse()
  Validates from <= to
end note
P --> ST : :FilterCommand(from, to)
deactivate P

ST -> FC : execute(expenseList, ui)
activate FC

loop for each expense in expenseList
    FC -> EL : getExpense(i)
    activate EL
    EL --> FC : expense
    deactivate EL
    FC -> FC : check date in [from, to]
end

FC -> UI : showFilteredExpenses(filtered, from, to)
activate UI
UI --> User : filtered expense table
deactivate UI
deactivate FC
deactivate ST

User -> ST : "find 2"
activate ST

ST -> P : parse(input)
activate P
P --> ST : :FindCommand(2)
deactivate P

ST -> FNC : execute(expenseList, ui)
activate FNC

FNC -> EL : size()
activate EL
EL --> FNC : size
deactivate EL

alt index out of range or list empty
    FNC -> FNC : throw SpendTrackException
else valid index
    FNC -> EL : getExpense(index - 1)
    activate EL
    EL --> FNC : expense
    deactivate EL
    FNC -> UI : showExpenseDetail(index, expense)
    activate UI
    UI --> User : detailed expense view
    deactivate UI
end

deactivate FNC
deactivate ST
@enduml
