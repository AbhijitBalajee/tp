@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Ui</u>" as UI

User -> ST : "summary" or "s"
activate ST

ST -> P : parse(input)
activate P
P -> P : resolve alias ("s" -> "summary")
create "<u>:SummaryCommand</u>" as SC
P -> SC : new SummaryCommand()
activate SC
SC --> P
deactivate SC
P --> ST : :SummaryCommand
deactivate P

ST -> SC : execute(expenses, ui)
activate SC

SC -> EL : getExpenses()
activate EL
EL --> SC : allExpenses
deactivate EL

alt expenses list is empty
    SC -> UI : showError("No expenses recorded yet.")
    activate UI
    UI --> SC
    deactivate UI
else expenses exist
    loop for each expense in allExpenses
        SC -> SC : update categoryTotals
        SC -> SC : update categoryCounts
        SC -> SC : update categoryMax
        SC -> SC : accumulate grandTotal
    end
    SC -> SC : sort categories descending by total
    SC -> UI : showEnhancedSummary(sorted, counts, max, grandTotal)
    activate UI
    note right of UI
      Food    : $13.50 (63%) | 3 txns | avg $4.50 | max $10.00
      Transport: $5.00 (37%) | 2 txns | avg $2.50 | max $3.00
    end note
    UI --> SC
    deactivate UI
end

SC --> ST
deactivate SC
ST --> User : output
deactivate ST
@enduml
