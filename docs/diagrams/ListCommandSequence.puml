@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Ui</u>" as UI

User -> ST : "list" or "list recurring"
activate ST
ST -> P : parse(input)
activate P
P -> P : check for "recurring" token

create participant "<u>:ListCommand</u>" as LC
P -> LC : new ListCommand(recurringOnly)
activate LC
LC --> P
deactivate LC

P --> ST : :ListCommand
deactivate P

ST -> LC : execute(expenseList, ui)
activate LC

alt recurringOnly == false
    LC -> UI : showExpenseList(expenses)
    activate UI
    UI -> EL : getExpense(i) for each i
    activate EL
    EL --> UI : expense
    deactivate EL
    note right of UI
        Calculates dynamic column
        widths before printing rows
    end note
    UI --> LC : formatted expense table
    deactivate UI
else recurringOnly == true
    LC -> UI : showRecurringList(expenses)
    activate UI
    UI -> EL : getExpense(i) for each i
    activate EL
    EL --> UI : expense
    deactivate EL
    note right of UI
        Filters to isRecurring == true
        then prints with dynamic widths
    end note
    UI --> LC : recurring expense table
    deactivate UI
end

LC --> ST
deactivate LC
ST --> User : expense table
deactivate ST
@enduml