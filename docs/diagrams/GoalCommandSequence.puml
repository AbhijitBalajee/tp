@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:GoalCommand</u>" as GC
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Ui</u>" as UI

User -> ST : "goal g/200"
activate ST

ST -> P : parse("goal g/200")
activate P
P -> P : parseGoalCommand("g/200")
note right of P
  Validates amount > 0.
  Throws SpendTrackException
  if invalid.
end note
P --> ST : :GoalCommand(200.0)
deactivate P

ST -> GC : execute(expenses, ui)
activate GC
GC -> EL : setGoal(200.0)
activate EL
EL --> GC
deactivate EL
GC -> UI : showMessage("Savings goal set to: $200.00")
activate UI
UI --> GC
deactivate UI
GC --> ST
deactivate GC

ST --> User : "Savings goal set to: $200.00"
ST -> ST : storage.save(expenses)
deactivate ST

User -> ST : "goal status"
activate ST

ST -> P : parse("goal status")
activate P
P --> ST : :GoalCommand (status)
deactivate P

ST -> GC : execute(expenses, ui)
activate GC

GC -> EL : hasGoal()
activate EL
EL --> GC : true
deactivate EL

GC -> EL : getGoal()
activate EL
EL --> GC : 200.0
deactivate EL

GC -> EL : getTotal()
activate EL
EL --> GC : 87.30
deactivate EL

alt spent <= goal
    GC -> UI : showMessage("Saved: $112.70 (56% of goal reached)")
    activate UI
    UI --> GC
    deactivate UI
else spent > goal
    GC -> UI : showMessage("Goal not reached. Over by $X.XX.")
    activate UI
    UI --> GC
    deactivate UI
end

GC --> ST
deactivate GC
ST --> User : output
deactivate ST
@enduml
