@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "<<class>>\nParser" as P
participant ":ClearCommand" as CC
participant ":ExpenseList" as EL
participant ":Ui" as UI

User -> ST : "clear"
activate ST

ST -> P : parse("clear")
activate P
P --> ST : :ClearCommand
deactivate P

ST -> CC : execute(expenses, ui)
activate CC

CC -> EL : size()
activate EL
EL --> CC : size
deactivate EL

alt size == 0
    CC -> UI : showMessage("No expenses to clear.")
    activate UI
    UI --> User : "No expenses to clear."
    deactivate UI
else size > 0
    CC -> UI : showMessage("Are you sure...? (yes/no):")
    activate UI
    UI --> User : "Are you sure...? (yes/no):"
    deactivate UI
    CC -> UI : readCommand()
    activate UI
    User -> UI : userInput
    UI --> CC : userInput
    deactivate UI
    alt userInput == "yes"
        CC -> EL : clearAll()
        activate EL
        EL --> CC
        deactivate EL
        CC -> UI : showMessage("All expenses cleared.")
        activate UI
        UI --> User : "All expenses cleared."
        deactivate UI
    else any other input
        CC -> UI : showMessage("Clear cancelled.")
        activate UI
        UI --> User : "Clear cancelled."
        deactivate UI
    end
end

deactivate CC

ST -> ST : storage.save(expenses)

deactivate ST
@enduml
