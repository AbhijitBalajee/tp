@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "Parser" as P
participant "DateParser" as DP
participant ":ExpenseList" as EL
participant ":BudgetChecker" as BC
participant ":Ui" as UI

User -> ST : "add d/Coffee a/3.50 c/food date/22-03-2026"
activate ST

ST -> P : parse(input)
activate P
P -> P : resolve alias
P -> P : parseAddCommand(args)
note right of P
  Splits args by regex
  to extract d/, a/, c/,
  date/ tokens in any order
end note

alt missing d/ or a/ flag
    P --> ST : throw SpendTrackException("Missing required field")
else valid flags present
    P -> P : normalizeCategory("food")
    note right of P : Returns "Food"

    opt date/ parameter provided
        P -> DP : parse("22-03-2026")
        activate DP
        DP --> P : LocalDate(2026-03-22)
        deactivate DP
    end

    create ":AddCommand" as AC
    P -> AC : new AddCommand("Coffee", 3.50, "Food", 2026-03-22)
    activate AC
    AC --> P
    deactivate AC
    P --> ST : :AddCommand
end
deactivate P

ST -> AC : execute(expenses, ui)
activate AC
create ":Expense" as E
AC -> E ** : new Expense("Coffee", 3.50, "Food", 2026-03-22, false)
activate E
E --> AC
deactivate E
AC -> EL : addExpense(expense)
activate EL
EL --> AC
deactivate EL
AC -> UI : showAddSuccess(expense)
activate UI
UI --> User : "Added: [Food] Coffee - $3.50 (2026-03-22)"
deactivate UI
AC -> BC : check(expenses, ui)
activate BC
alt totalSpent > budget
    BC -> UI : showBudgetAlert(...)
else totalSpent >= 90% of budget
    BC -> UI : showBudgetWarning(...)
else under threshold
end
deactivate BC
deactivate AC

deactivate ST
@enduml
