@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:UndoManager</u>" as UM
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Ui</u>" as UI

User -> ST : "add d/Mistake a/999 c/Oops"
activate ST
ST -> P : parse(input, undoManager)
activate P
create "<u>:AddCommand</u>" as AC
P -> AC : new AddCommand(...)
activate AC
AC --> P
deactivate AC
P --> ST : :AddCommand
deactivate P

ST -> ST : command.mutatesData()?
note right of ST : returns true

ST -> UM : saveSnapshot(expenses)
activate UM
UM -> UM : deepCopyExpenses()
note right of UM
  Creates new Expense objects
  so snapshot is independent
  of future mutations
end note
UM --> ST
deactivate UM

ST -> AC : execute(expenses, ui)
activate AC
AC -> EL : addExpense(expense)
activate EL
EL --> AC
deactivate EL
AC -> UI : showAddSuccess(expense)
activate UI
UI --> AC
deactivate UI
AC --> ST
deactivate AC

ST -> ST : storage.save(expenses)
ST --> User : "New expense added: ..."
deactivate ST

User -> ST : "undo"
activate ST
ST -> P : parse("undo", undoManager)
activate P
create "<u>:UndoCommand</u>" as UC
P -> UC : new UndoCommand(undoManager)
activate UC
UC --> P
deactivate UC
P --> ST : :UndoCommand
deactivate P

ST -> UC : execute(expenses, ui)
activate UC
UC -> UM : undo(expenses)
activate UM
UM -> EL : restoreFrom(snapshot, snapshotBudget)
activate EL
EL --> UM
deactivate EL
UM --> UC : true
deactivate UM
UC -> UI : print "Last command undone successfully."
activate UI
UI --> UC
deactivate UI
UC --> ST
deactivate UC

ST -> ST : storage.save(expenses)
ST --> User : "Last command undone successfully."
deactivate ST
@enduml
