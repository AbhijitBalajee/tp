@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<u>:Storage</u>" as S
participant "<u>:ExpenseList</u>" as EL
participant "<u>:Expense</u>" as E
participant "<u>:Ui</u>" as UI

User -> ST : launch app
activate ST

ST -> S : load(expenseList)
activate S

alt save file exists
    loop for each line in file
        alt line is EXPENSES marker
            S -> S : set mode = EXPENSES
        else line is BUDGET marker
            S -> S : set mode = BUDGET
        else line is BUDGET-HISTORY marker
            S -> S : set mode = HISTORY
        else mode = EXPENSES
            S -> S : parseLine(line)
            opt checksum mismatch
                S -> S : print tamper warning, skip line
            end
            S -> S : validateExpense(desc, amt, date)
            opt validation fails
                S -> S : print warning, skip line
            end
            S -> E ** : new Expense(desc, amt, cat, date, recurring)
            S -> EL : addExpense(expense)
            activate EL
            EL --> S
            deactivate EL
        else mode = BUDGET
            S -> EL : setBudgetDirectly(amount)
            activate EL
            EL --> S
            deactivate EL
        else mode = HISTORY
            S -> EL : addBudgetHistory(entry)
            activate EL
            EL --> S
            deactivate EL
        end
    end
    S --> ST
else save file missing
    S -> S : log "No save file found. Starting fresh."
    S --> ST
end

deactivate S

opt expenseList is non-empty
    ST -> UI : showLastExpense(lastExpense)
    activate UI
    UI --> User : "Last recorded expense: ..."
    deactivate UI
end

ST -> UI : showWelcome()
activate UI
UI --> User : welcome message
deactivate UI

deactivate ST
@enduml
