@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant ":Storage" as S
participant ":ExpenseList" as EL
participant ":Expense" as E
participant ":Ui" as UI

User -> ST : launch app
activate ST

ST -> S : load(expenseList)
activate S

alt save file exists
    loop for each line in file
        alt line is EXPENSES marker
            S -> S : set mode = EXPENSES
        else line is BUDGET marker
            S -> S : set mode = BUDGET
        else line is BUDGET-HISTORY marker
            S -> S : set mode = HISTORY
        else mode = EXPENSES
            S -> S : parseLine(line)
            S -> E ** : new Expense(desc, amt, cat, date)
            S -> EL : addExpense(expense)
            activate EL
            EL --> S
            deactivate EL
        else mode = BUDGET
            S -> EL : setBudgetDirectly(amount)
            activate EL
            EL --> S
            deactivate EL
        else mode = HISTORY
            S -> EL : addBudgetHistory(entry)
            activate EL
            EL --> S
            deactivate EL
        end
    end
else save file missing
    S -> S : log "No save file found. Starting fresh."
end

S --> ST
deactivate S

opt expenseList is non-empty
    ST -> UI : showLastExpense(lastExpense)
    activate UI
    UI --> User : "Last recorded expense: ..."
    deactivate UI
end

ST -> UI : showWelcome()
activate UI
UI --> User : welcome message
deactivate UI

deactivate ST
@enduml
