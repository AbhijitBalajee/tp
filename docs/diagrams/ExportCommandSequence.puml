@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant "<u>:SpendTrack</u>" as ST
participant "<<class>>\nParser" as P
participant "<u>:ExportCommand</u>" as EC
participant "<u>:ExpenseList</u>" as EL

User -> ST : "export csv"
activate ST

ST -> P : parse("export csv")
activate P
note right of P
  Checks for "csv" sub-command.
  Throws SpendTrackException
  if missing.
end note
P --> ST : :ExportCommand
deactivate P

ST -> EC : execute(expenses, ui)
activate EC

EC -> EL : size()
activate EL
EL --> EC : size
deactivate EL

alt size == 0
    EC --> ST : "No expenses to export."
    ST --> User : "No expenses to export."
else size > 0
    EC -> EC : ensureDirectoryExists()
    EC -> EC : new FileWriter("data/spendtrack_export.csv")
    EC -> EC : write(CSV_HEADER)
    loop for each expense in list
        EC -> EC : formatCsvRow(expense)
        note right of EC
          Wraps description in
          double quotes if it
          contains commas
        end note
        EC -> EC : write(csvRow)
    end
    EC --> ST : "Expenses exported to data/spendtrack_export.csv"
    ST --> User : "Expenses exported to data/spendtrack_export.csv"
end

deactivate EC
deactivate ST
@enduml
