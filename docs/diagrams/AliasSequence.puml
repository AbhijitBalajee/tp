@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "Parser" as P
participant ":SummaryCommand" as SC

User -> ST : "s"
activate ST

ST -> P : parse("s")
activate P
P -> P : split into commandWord="s", args=""
P -> P : lowercase commandWord
P -> P : ALIASES.getOrDefault("s", "s")
note right of P : resolves to "summary"
P --> ST : :SummaryCommand
deactivate P

ST -> SC : execute(expenses, ui)
activate SC
SC --> User : summary output
deactivate SC

deactivate ST
@enduml
