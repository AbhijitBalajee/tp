@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "<<class>>\nParser" as P
participant ":AddCommand" as AC
participant ":ExpenseList" as EL
participant "<<class>>\nBudgetChecker" as BC
participant ":Ui" as UI

User -> ST : "add d/Dinner a/50 c/Food"
activate ST

ST -> P : parse(input)
activate P
P --> ST : :AddCommand
deactivate P

ST -> AC : execute(expenses, ui)
activate AC
AC -> EL : addExpense(expense)
activate EL
EL --> AC
deactivate EL
AC -> UI : showAddSuccess(expense)
activate UI
UI --> User : "New expense added: ..."
deactivate UI

AC -> BC : check(expenses, ui)
activate BC
BC -> EL : hasBudget()
activate EL
EL --> BC : true
deactivate EL

BC -> EL : getTotal()
activate EL
EL --> BC : totalSpent
deactivate EL

BC -> EL : getBudget()
activate EL
EL --> BC : budget
deactivate EL

alt totalSpent > budget
    BC -> UI : showBudgetAlert(totalSpent, budget)
    activate UI
    UI --> User : "[ALERT] You have exceeded..."
    deactivate UI
else usageRatio >= 0.9
    BC -> UI : showBudgetWarning(totalSpent, budget)
    activate UI
    UI --> User : "[WARNING] You are close..."
    deactivate UI
else under 90%
    note right of BC : No message shown
end

BC --> AC
deactivate BC
AC --> ST
deactivate AC

ST -> ST : storage.save(expenses)

deactivate ST
@enduml
