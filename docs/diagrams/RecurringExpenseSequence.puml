@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "Parser" as P
participant ":ExpenseList" as EL
participant ":Ui" as UI

note over ST, UI : Add recurring expense

User -> ST : "add d/Netflix a/18.00 c/Entertainment recurring/true"
activate ST
ST -> P : parse(input)
activate P
P -> P : parseAddCommand(args)
note right of P
    Extracts recurring/true token
    validates value is true or false
end note

create participant ":AddCommand" as AC
P -> AC : new AddCommand(..., isRecurring=true)
activate AC
AC --> P
deactivate AC

P --> ST : :AddCommand
deactivate P

ST -> AC : execute(expenseList, ui)
activate AC
AC -> ":Expense" as E ** : new Expense(..., isRecurring=true)
AC -> EL : addExpense(expense)
activate EL
EL --> AC
deactivate EL
AC -> UI : showAddSuccess(expense)
activate UI
UI --> User : "New expense added: ... [R]"
deactivate UI
deactivate AC
deactivate ST

note over ST, UI : List recurring expenses

User -> ST : "list recurring"
activate ST
ST -> P : parse("list recurring")
activate P

create participant ":ListCommand" as LC
P -> LC : new ListCommand(recurringOnly=true)
activate LC
LC --> P
deactivate LC

P --> ST : :ListCommand
deactivate P

ST -> LC : execute(expenseList, ui)
activate LC
LC -> UI : showRecurringList(expenses)
activate UI
UI -> EL : getExpense(i) for each i
activate EL
EL --> UI : expense
deactivate EL
note right of UI
    Filters expenses where
    isRecurring == true
end note
UI --> User : recurring expense table
deactivate UI
deactivate LC
deactivate ST
@enduml