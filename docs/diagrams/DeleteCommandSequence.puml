@startuml
!define BGCOLOR white
skinparam backgroundColor BGCOLOR
skinparam sequenceMessageAlign center

actor User
participant ":SpendTrack" as ST
participant "<<class>>\nParser" as P
participant ":DeleteCommand" as DC
participant ":ExpenseList" as EL
participant ":Ui" as UI

User -> ST : "delete 2"
activate ST

ST -> P : parse("delete 2")
activate P
P -> P : parse index as integer
note right of P
  Throws SpendTrackException
  if index is non-integer
  or missing
end note
P --> ST : :DeleteCommand(2)
deactivate P

ST -> DC : execute(expenseList, ui)
activate DC

DC -> EL : size()
activate EL
EL --> DC : size
deactivate EL

alt index < 1 or index > size
    DC -> DC : throw SpendTrackException\n("Index out of range...")
else valid index
    DC -> EL : getExpense(index - 1)
    activate EL
    EL --> DC : expense
    deactivate EL
    DC -> UI : confirmDelete(expense)
    activate UI
    UI --> User : "About to delete: ... Are you sure? (yes/no)"
    User --> UI : response
    deactivate UI
    opt response != "yes"
        DC -> UI : showMessage("Delete cancelled.")
        activate UI
        UI --> User : "Delete cancelled."
        deactivate UI
        DC --> ST
    end
    DC -> EL : deleteExpense(index - 1)
    activate EL
    EL --> DC : removedExpense
    deactivate EL
    DC -> UI : showDeleteSuccess(removedExpense)
    activate UI
    UI --> User : "Expense deleted: ..."
    deactivate UI
end

deactivate DC

ST -> ST : command.mutatesData() == true
ST -> ST : storage.save(expenseList)

deactivate ST
@enduml
